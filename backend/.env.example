# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=DEBUG

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Cloud Tasks
CLOUD_TASKS_QUEUE=spark-agent-tasks
CLOUD_TASKS_LOCATION=us-central1
CLOUD_RUN_SERVICE_URL=http://localhost:8000

# Cloud Storage
GCS_BUCKET_NAME=spark-documents

# BigQuery
BIGQUERY_DATASET=spark_analytics

# Pub/Sub
PUBSUB_TOPIC=spark-events

# Google OAuth
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# CORS — accepts either format:
# Comma-separated: http://localhost:5173,http://localhost:3000
# JSON array:      ["http://localhost:5173","http://localhost:3000"]
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000